# ── Required for AI mode ───────────────────────────────────────────────────────
# Get your API key at https://console.anthropic.com
# Without this key the app runs in free rule-based mode (no AI narrative).
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Analyses allowed per user session per day
DAILY_LIMIT=10

# Max upload file size in MB
MAX_FILE_SIZE_MB=10

# App title shown in the browser tab and header
APP_TITLE=🔍 EDA Agent — Powered by Claude

# Claude model — claude-sonnet-4-20250514 is the recommended default
# Other options: claude-opus-4-6, claude-haiku-4-5-20251001 (faster/cheaper)
CLAUDE_MODEL=claude-sonnet-4-20250514
